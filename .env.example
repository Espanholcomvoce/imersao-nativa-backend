# ══════════════════════════════════════════════════════════
# IMERSÃO NATIVA - Template de Variáveis de Ambiente
# ══════════════════════════════════════════════════════════
#
# INSTRUÇÕES:
# 1. NÃO commite este arquivo com valores reais
# 2. No Railway: cole cada variável em Settings → Variables
# 3. Localmente: copie para .env e preencha os valores
#
# ══════════════════════════════════════════════════════════

# ── SERVIDOR ──────────────────────────────────────────────
# Railway configura PORT automaticamente — não precisa mudar
PORT=3001
NODE_ENV=production

# URL do seu frontend no Netlify (sem barra no final)
# Exemplo: https://imersaonativa.netlify.app
FRONTEND_URL=https://SEU-APP.netlify.app


# ── AUTENTICAÇÃO JWT ──────────────────────────────────────
# Gere um segredo forte rodando no terminal:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
# IMPORTANTE: use o mesmo valor sempre — se mudar, todos os
# usuários logados serão desconectados
JWT_SECRET=cole-aqui-um-segredo-longo-e-aleatorio
JWT_EXPIRES_IN=7d


# ── HOTMART ───────────────────────────────────────────────
# Seu Hottok da API Hotmart
# Onde encontrar: Hotmart → Ferramentas → API → Hottok
HOTMART_HOTTOK=seu-hottok-aqui

# Emails com acesso liberado para testes (separados por vírgula)
# Útil para testar sem precisar de assinatura ativa
# DEMO_EMAILS=voce@email.com,teste@email.com


# ── ANTHROPIC (Claude - Chat) ─────────────────────────────
# Sua chave da API Anthropic
# Onde encontrar: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...


# ── ELEVENLABS (Text to Speech) ───────────────────────────
# Sua chave da API ElevenLabs
# Onde encontrar: elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=sua-chave-elevenlabs-aqui


# ── OPENAI (Conversa em Tempo Real) ───────────────────────
# Sua chave da API OpenAI (precisa ter acesso ao Realtime API)
# Onde encontrar: platform.openai.com → API Keys
OPENAI_API_KEY=sk-proj-...

# Limite de minutos de conversa em tempo real por usuário por dia
# Padrão: 15 minutos
REALTIME_DAILY_MINUTES=15
